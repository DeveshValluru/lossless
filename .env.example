# ---- Google Cloud / Gemini ----
# Easiest local path: an AI Studio key (https://aistudio.google.com/apikey).
GOOGLE_API_KEY=

# Recommended for the deployed Cloud Run submission ("uses Google Cloud" story).
# Requires `gcloud auth application-default login` or a service-account JSON
# pointed to by GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# Model. We default to Gemini 3 Pro (hackathon requirement) and fall back to
# 2.5 Flash automatically if 3-pro isn't enabled on the account.
GEMINI_MODEL=gemini-3-pro
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# ---- Dynatrace (Partner MCP) ----
# Get from your Dynatrace tenant: https://www.dynatrace.com/trial
DT_ENVIRONMENT=https://YOUR_TENANT.live.dynatrace.com
# Platform token with scopes: storage:metrics:read, storage:logs:read,
# storage:events:read, storage:problems:read, environment-api:problems:read
DT_PLATFORM_TOKEN=dt0s16.xxxxx

# ---- App ----
APP_PORT=8080
DEMO_MODE=true   # When true, agent uses synthetic telemetry if Dynatrace is empty
